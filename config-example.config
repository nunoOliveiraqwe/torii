log:
  debug: false
  logLevel: DEBUG
  encoding: console # Log encoding format: "console" (human-readable) or "json" (structured)
  color: true       # Colored log levels (only applies when encoding is "console")

apiServer:
  host: 127.0.0.1
  port: 27000

netConfig:
  http:
    - port: 8091
      bind: 3
      default:
        backend: http://localhost:8095
        middlewares:
          - type: "RequestId"
          - type: "RequestLog"
          - type: "IpBlock"
            options:
              allow:
                - 192.168.1.1/24
                - 2001:db8::/32
                - 10.10.10.180
              block:
                - 94.0.0.1/24
                - 2001:db8:1234::/48
                - 182.78.86.62
              # --- AbuseIPDB (optional) ---
              # When configured, the block list is fetched from AbuseIPDB instead of
              # the static 'block' list above. The 'allow' list still applies as a
              # whitelist override.
              # abuseipdb-api-key: "$env:ABUSEIPDB_API_KEY"   # Supports $env:VAR and $file:/path, or just the raw API key string
              # abuseipdb-confidence-minimum: 90               # Min abuse confidence score (1-100)
              # abuseipdb-refresh-interval: "24h"              # How often to re-fetch
          - type: "Cors"
            options:
              allow-origin: "*" # Allowed origins for CORS requests (e.g., "*", "https://example.com")
              allow-methods: "GET, POST, PUT, DELETE" # Allowed HTTP methods for CORS requests (e.g., "GET, POST")
              allow-headers: "Content-Type, Authorization" # Allowed headers for CORS requests (e.g., "Content-Type, Authorization")
              max-age: 3600 # Max age for preflight request caching in seconds (e.g., 3600 for 1 hour)
          - type: "UserAgentBlocker"
            options:
              cache-ttl: 24h # Time to live for the cached banned IPs, e.g., 24h for 24 hours, 1ms for 1 millisecond
              cleanup-interval: 1h # Interval for cleaning up expired cache entries, e.g., 1h for 1 hour, 30m for 30 minutes
              max-cache-size: 100000 # Max number of entries in the cache, e.g., 10000
              block-empty-ua: true # Whether to block requests with an empty User-Agent header (true or false)
              block-defaults: # Category names from the built-in UA pattern list
                - "scanners"
                - "recon"
                - "scrapers"
                - "headless"
                - "malicious"
                - "http-clients"
                - "cli-tools"
                - "ai-crawlers"
              block:
                - "bad-bot-that-i-want-to-block" # Custom block list of user-agent substrings, e.g., "bad-bot", "evil-scraper"
              allow-defaults: # Category names to always allow, overrides blocks
                - "search-engines"
              allow: #If a user-agent matches both block and allow lists, the allow list takes precedence and the request will be allowed. An empty allow means allow everything not blocked
                - "googlebot"
          - type: "HoneyPot"
            options:
              cache-ttl: 24h # Time to live for the cached banned IPs, e.g., 24h for 24 hours, 1ms for 1 millisecond
              cleanup-interval: 1h # Interval for cleaning up expired cache entries, e.g., 1h for 1 hour, 30m for 30 minutes
              max-cache-size: 100000 # Max number of entries in the cache, e.g., 10000
              defaults:
                - "git"
                - "infra"
                - "backups"
                - "cgi"
                # "php" omitted — running a real PHP app
              paths:
                - "/my-custom-trap-path"
              response:
                trickster-mode: true # Will reply with weird responses designed to fuck with the bots, if set, status-code and body will not apply
                max-slow-tricks: 10 #Max number of slow concurrent request. Careful with this because not only will it slow bot, by tying up their connection, it will tie up yours. Ignored if trickster is false
                status-code: 403 # HTTP status code to return for requests that hit the honeypot (e.g., 403 for Forbidden, 404 for Not Found)
                body: "Forbidden" # Response body to return for requests that hit the honeypot
          - type: "CircuitBreaker"
            options:
              failure-threshold: 5 # Number of consecutive failures to trip the circuit breaker
              recovery-time: 30s # Time to wait before attempting to reset the circuit breaker (e.g., 30s for 30 seconds, 1m for 1 minute)
              half-open-success-threshold: 3 # Number of consecutive successful requests in half-open state to reset the circuit breaker
          - type: "Timeout"
            options:
              request-timeout: 30s # Maximum allowed time for the entire request (e.g., 30s for 30 seconds, 1m for 1 minute)
          - type: "BodySizeLimit"
            options:
              max-size: 100m # Maximum allowed request body size (e.g., 10m for 10 megabytes, 1g for 1 gigabyte)
          - type: "Redirect"
            options:
              mode: "internal" # Redirect mode (internal or external), internal will proxy the request to the target, external will respond with a redirect status code and Location header pointing to the target, careful with external mode because it can cause redirect loops if not configured correctly
              status-code: 302 # HTTP status code for the redirect (e.g., 301 for permanent redirect, 302 for temporary redirect), only applies to external mode
              target: 192.168.1.109:8092
              drop-path: true # Whether to drop the original request path when redirecting (true or false)
              drop-query: true # Whether to drop the original query parameters when redirecting (true or false)

        paths:
          # Exact match: only /health gets just RequestId
          - pattern: /health
            middlewares:
              - type: "RequestId"
          - pattern: /api/v1/users/*
            middlewares:
              - type: "Metrics"
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Headers"
                options:
                  set-headers-res:
                    X-Api-Version: "1.0"
                  cmp-headers-req:
                    X-Proxy-Id: Torii


          - pattern: /api/v1/users/*/start
            middlewares:
              - type: "Metrics"
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Headers"
                options:
                  set-headers-res:
                    X-Api-Version: "1.0"


          - pattern: /users/*/start
            middlewares:
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Metrics"


          - pattern: /users/admin/start
            middlewares:
              - type: "RequestId"
              - type: "Metrics"


          - pattern: /static/
            middlewares:
              - type: "RequestId"


    - port: 8092
      bind: 1
      interface: en0
      tls:
       use-acme: true
      routes:
        - host: immitch.mydomain.pt
          target:
            backend: http://192.168.1.27:2283
            middlewares:
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Metrics" # I keep forgetting that metrics have to be explicitly added to each route, I might just change this to always inject it
              - type: "CountryBlock"
                options:
                  source:
                    mode: "remote" # Source for the country code (remote | local)
                    path: "https://github.com/iplocate/ip-address-databases/raw/refs/heads/main/ip-to-country/ip-to-country.mmdb" # URL to fetch the country code when mode is "remote" or file path when mode is "local"
                    country-field: "country_code" # Field name in the DB file that contains the country code, e.g., "country_code", . is used a delimiter for nested fields, country.iso_code for {"country": {"iso_code": "US"}} in the DB file
                    continent-field: "continent_code" # Field name in the DB file that contains the continent code, e.g., "continent_code", . is used a delimiter for nested fields, continent.code for {"continent": {"code": "EU"}} in the DB file, optional, if not specified, continent code will not be used for blocking
                    max-size: 300m # Max size of the downloaded DB file, e.g., 300m for 300 megabytes, ignored when source is "local"
                    refresh-interval: 24h # Interval for refreshing the DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond, ignored when source is "local"
                  cache-ttl: 24h # Time to live for the cached DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond
                  cleanup-interval: 1h # Interval for cleaning up expired cache files, e.g., 1h for 1 hour, 30m for 30 minutes
                  max-cache-size: 10000 # Max number of entries in the cache, e.g., 10000 for 10,000 entries
                  on-unknown: block # Action when country/continent code cannot be resolved (allow | block), default: block

                  # --- Policy evaluation ---
                  # At least one of country-list or continent-list must be specified.
                  #
                  # If only country-list is defined, the country policy alone decides.
                  # If only continent-list is defined, the continent policy alone decides.
                  #
                  # If BOTH are defined, the continent policy is the broad/base policy
                  # and the country policy acts as an exception override:
                  #   1. The country list is checked first.
                  #      If the country code IS in the list, the country-list-mode decides
                  #      immediately (allow → allow, block → block), overriding the continent policy.
                  #   2. If the country code is NOT in the list, the continent policy applies.
                  #
                  # Example below: continent EU is blocked, but PT and CA are explicitly allowed
                  # as exceptions. A request from PT (in EU) is allowed; a request from DE (in EU,
                  # not in the country allow list) is blocked by the continent policy.

                  country-list-mode: allow # Mode for the country list (allow | block)
                  country-list:
                    - PT
                    - CA
                  continent-list-mode: block # Mode for the continent list (allow | block)
                  continent-list:
                    - EU

        - host: static.localhost:8092
          target:
            backend: http://localhost:8095
            middlewares:
              - type: "RequestId"

            paths:
              - pattern: /jellyfin/*
                backend: http://192.168.1.100:8096 # Optional: overrides the route backend for this path
                drop-path: true   # Strip the matched path prefix — /jellyfin/foo proxies to backend as /foo
                drop-query: false # Preserve query parameters (default: false)
                middlewares:
                  - type: "Metrics"
                  - type: "RequestId"
                  - type: "RequestLog"
                  - type: "IpBlock"
                    options:
                      allow:
                       - 192.1.1.1
                       - 192.168.1.1/24
                       - 2001:db8::/32
                  - type: "RateLimiter"
                    options:
                      mode: "per-client"
                      cache-ttl: 24h # Time to live for the cached DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond, ignored if mode is "global"
                      cleanup-interval: 1h # Interval for cleaning up expired cache files, e.g., 1h for 1 hour, 30m for 30 minutes, ignored if mode is "global"
                      max-cache-size: 10000 # Max number of entries in the cache, e.g., 10000 for 10,000 entries, ignored if mode is "global"
                      limiter-req:
                        rate-per-second: 5
                        burst: 10
                  - type: "Headers"
                    options:
                      cmp-headers-req:
                        X-Host-Name: immitch.omeudominio.it


      default:
        backend: http://localhost:8095
        middlewares:
          - type: "RequestId"

