log:
  debug: false
  logLevel: DEBUG
  encoding: console # Log encoding format: "console" (human-readable) or "json" (structured)
  color: true       # Colored log levels (only applies when encoding is "console")

apiServer:
  host: 127.0.0.1
  port: 27000

netConfig:
  http:
    - port: 8091
      bind: 3
      default:
        backend: http://localhost:8095
        middlewares:
          - type: "RequestId"
          - type: "RequestLog"
          - type: "Redirect"
              options:
                status-code: 302 # HTTP status code for the redirect (e.g., 301 for permanent redirect, 302 for temporary redirect)
                target: localhost:8092
                drop-path: true # Whether to drop the original request path when redirecting (true or false)
                drop-query: true # Whether to drop the original query parameters when redirecting (true or false)

        paths:
          # Exact match: only /health gets just RequestId
          - pattern: /health
            middlewares:
              - type: "RequestId"



          - pattern: /api/v1/users/*
            middlewares:
              - type: "Metrics"
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Headers"
                options:
                  set-headers-res:
                    X-Api-Version: "1.0"
                  cmp-headers-req:
                    X-Proxy-Id: Torii


          - pattern: /api/v1/users/*/start
            middlewares:
              - type: "Metrics"
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Headers"
                options:
                  set-headers-res:
                    X-Api-Version: "1.0"


          - pattern: /users/*/start
            middlewares:
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Metrics"


          - pattern: /users/admin/start
            middlewares:
              - type: "RequestId"
              - type: "Metrics"


          - pattern: /static/
            middlewares:
              - type: "RequestId"


    - port: 8092
      bind: 3
      interface: en0
      tls:
       use-acme: true
      routes:
        - host: immitch.mydomain.pt
          target:
            backend: http://192.168.1.27:2283
            middlewares:
              - type: "RequestId"
              - type: "RequestLog"
              - type: "Metrics" # I keep forgetting that metrics have to be explicitly added to each route, I might just change this to always inject it
              - type: "CountryBlock"
                options:
                  source:
                    mode: "remote" # Source for the country code (remote | local)
                    path: "https://github.com/iplocate/ip-address-databases/raw/refs/heads/main/ip-to-country/ip-to-country.mmdb" # URL to fetch the country code when mode is "remote" or file path when mode is "local"
                    country-field: "country_code" # Field name in the DB file that contains the country code, e.g., "country_code", . is used a delimiter for nested fields, country.iso_code for {"country": {"iso_code": "US"}} in the DB file
                    continent-field: "continent_code" # Field name in the DB file that contains the continent code, e.g., "continent_code", . is used a delimiter for nested fields, continent.code for {"continent": {"code": "EU"}} in the DB file, optional, if not specified, continent code will not be used for blocking
                    max-size: 300m # Max size of the downloaded DB file, e.g., 300m for 300 megabytes, ignored when source is "local"
                    refresh-interval: 24h # Interval for refreshing the DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond, ignored when source is "local"
                  cache-ttl: 24h # Time to live for the cached DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond
                  cleanup-interval: 1h # Interval for cleaning up expired cache files, e.g., 1h for 1 hour, 30m for 30 minutes
                  max-cache-size: 10000 # Max number of entries in the cache, e.g., 10000 for 10,000 entries
                  on-unknown: block # Action when country/continent code cannot be resolved (allow | block), default: block

                  # --- Policy evaluation ---
                  # At least one of country-list or continent-list must be specified.
                  #
                  # If only country-list is defined, the country policy alone decides.
                  # If only continent-list is defined, the continent policy alone decides.
                  #
                  # If BOTH are defined, the continent policy is the broad/base policy
                  # and the country policy acts as an exception override:
                  #   1. The country list is checked first.
                  #      If the country code IS in the list, the country-list-mode decides
                  #      immediately (allow → allow, block → block), overriding the continent policy.
                  #   2. If the country code is NOT in the list, the continent policy applies.
                  #
                  # Example below: continent EU is blocked, but PT and CA are explicitly allowed
                  # as exceptions. A request from PT (in EU) is allowed; a request from DE (in EU,
                  # not in the country allow list) is blocked by the continent policy.

                  country-list-mode: allow # Mode for the country list (allow | block)
                  country-list:
                    - PT
                    - CA
                  continent-list-mode: block # Mode for the continent list (allow | block)
                  continent-list:
                    - EU

        - host: static.localhost:8092
          target:
            backend: http://localhost:8095
            middlewares:
              - type: "RequestId"

            paths:
              - pattern: /api/*
                middlewares:
                  - type: "Metrics"
                  - type: "RequestId"
                  - type: "RequestLog"
                  - type: "IpBlock"
                    options:
                      list-mode: allow # Mode for the IP address (allow | block)
                      list:
                       - 192.1.1.1
                       - 192.168.1.1 /24
                       - 2001:db8::/32
                  - type: "RateLimiter"
                    options:
                      mode: "per-client"
                      cache-ttl: 24h # Time to live for the cached DB file, e.g., 24h for 24 hours, 1ms for 1 millisecond, ignored if mode is "global"
                      cleanup-interval: 1h # Interval for cleaning up expired cache files, e.g., 1h for 1 hour, 30m for 30 minutes, ignored if mode is "global"
                      max-cache-size: 10000 # Max number of entries in the cache, e.g., 10000 for 10,000 entries, ignored if mode is "global"
                      limiter-req:
                        rate-per-second: 5
                        burst: 10
                  - type: "Headers"
                    options:
                      cmp-headers-req:
                        X-Host-Name: immitch.omeudominio.it


      default:
        backend: http://localhost:8095
        middlewares:
          - type: "RequestId"

